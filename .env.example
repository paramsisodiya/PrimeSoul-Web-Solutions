# PrimeSoul Environment Variables
# Copy this file to .env.local and fill in the values

# ── MongoDB ────────────────────────────────────────────────
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/primesoul

# ── Email (Nodemailer / Gmail App Password) ────────────────
# SMTP_USER=paramsisodiya061@gmail.com
# SMTP_PASS=your_gmail_app_password

# ── Admin JWT ──────────────────────────────────────────────
# JWT_SECRET=your_very_long_random_secret_key_here
# ADMIN_EMAIL=paramsisodiya061@gmail.com
# ADMIN_PASSWORD=your_secure_admin_password

# ── App ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=918770404559

# Firebase (required for admin panel, CMS content, leads, blog, portfolio)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# EmailJS (required for contact form email notification)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
